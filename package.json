{
  "name": "atelier",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter storefront dev",
    "build": "pnpm --filter storefront build",
    "start": "pnpm --filter storefront start",
    "lint": "pnpm --filter storefront lint",
    "test": "pnpm -r test",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:dev:generate": "prisma generate --schema prisma/schema.sqlite.prisma",
    "db:dev:push": "prisma db push --schema prisma/schema.sqlite.prisma",
    "db:dev:seed": "DATABASE_URL=file:./prisma/dev.db tsx prisma/seed.ts",
    "db:postgres:generate": "prisma generate --schema prisma/schema.postgres.prisma",
    "db:postgres:push": "prisma db push --schema prisma/schema.postgres.prisma",
    "db:sqlite:export": "python3 scripts/export_sqlite_snapshot.py",
    "db:postgres:import": "tsx scripts/import_sqlite_snapshot_to_postgres.ts"
  },
  "devDependencies": {
    "prisma": "^6.14.0",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "@prisma/client": "^6.14.0"
  }
}
