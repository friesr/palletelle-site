    "db:seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "prisma": "^6.14.0",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "@prisma/client": "^6.14.0"
  }
}
